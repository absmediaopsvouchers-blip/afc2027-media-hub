# =============================================================================
#  AFC Asian Cup 2027 — Meal Vouchers & Media Info Hub
#  Environment configuration. Copy this file to ".env" for local development,
#  or set these as environment variables on your cloud host (Render / Fly.io).
# =============================================================================

# Port the server listens on.
# Most cloud hosts assign this automatically — leave it to them in production.
# Locally it defaults to 3000 if unset.
PORT=3000

# -----------------------------------------------------------------------------
# Database connection string (optional).
#
# Leave BLANK to use the built-in, zero-config JSON file store (data.json) — great
# for local development and a single-laptop venue deployment.
#
# Set it on your cloud host to persist data across instance recycles. The driver
# is auto-detected from the URL scheme:
#
#   • PostgreSQL (Neon / Supabase / Render Postgres):
#       DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#
#   • MongoDB (MongoDB Atlas):
#       DATABASE_URL=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/dbname
# -----------------------------------------------------------------------------
DATABASE_URL=

# Admin dashboard key. Protects the /admin dashboard and all admin APIs over the
# public internet. REQUIRED — the server refuses to boot if this is unset, and
# there is no built-in default. Use a long, random value.
ADMIN_KEY=

# Volunteer key. Grants access ONLY to the voucher redeemer (/admin/redeem) —
# volunteers cannot view analytics, exports, or manage content. REQUIRED — the
# server refuses to boot if this is unset. Use a long, random value.
VOLUNTEER_KEY=

# IANA timezone used to compute the calendar day for voucher limits and the
# daily reset (resets at local midnight in this zone, not server UTC).
# Examples: Asia/Riyadh, Asia/Qatar, Asia/Baku, Asia/Dubai
EVENT_TIMEZONE=Asia/Riyadh

# CORS allowlist (R-7): comma-separated origins allowed to call this API from a
# browser on a different domain — i.e. the Central Dashboard. The Media Hub's
# own /admin and client pages are same-origin and do NOT need this. Leave blank
# to forbid all cross-origin browser access (secure default). Example:
#   ALLOWED_ORIGINS=https://afc2027-central-dashboard.onrender.com
ALLOWED_ORIGINS=
